# Variables para Portainer — Stack → Environment variables
# Copia cada línea NAME=VALUE en el editor de Portainer (sin #)

WG_HOST=203.0.113.45
ADMIN_USER=admin
ADMIN_PASSWORD=CambiaEstaClave123!
JWT_SECRET=genera_con_openssl_rand_hex_32_minimo_64_caracteres_hex
# WEB_PORT no hace falta — fijado en 51822 en docker-compose.yml
WG_PORT=443
VPN_MODE=gaming
WG_MTU=1280
WG_PERSISTENT_KEEPALIVE=15
TZ=Europe/Madrid
COMPOSE_PROJECT_NAME=vpn

# Opcional HTTPS (perfil ssl):
# PANEL_DOMAIN=vpn.tudominio.com
# ACME_EMAIL=tu@email.com
