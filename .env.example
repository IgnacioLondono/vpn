# =============================================================================
# VP´N — Portal web + WireGuard
# cp .env.example .env && edita los valores
# =============================================================================

# IP o dominio público del servidor
WG_HOST=

# Dominio HTTPS del panel (opcional)
PANEL_DOMAIN=
ACME_EMAIL=

# ── UN SOLO PUERTO VPN (UDP) ──────────────────────────────────────────────
# 443 UDP suele pasar mejor firewalls/routers. Solo abre ESTE puerto para VPN.
WG_PORT=443

# Panel web — puerto TCP 8443 (VPN usa WG_PORT/UDP 443)
WEB_PORT=8443

# Credenciales del panel
ADMIN_USER=admin
ADMIN_PASSWORD=
JWT_SECRET=

# ── MODO VPN ───────────────────────────────────────────────────────────────
# gaming  = recomendado: túnel activo SIN reenrutar juegos (no te expulsa)
# full    = todo el tráfico por VPN (más privacidad, peor para juegos online)
VPN_MODE=gaming

# Estabilidad / anti-pérdida de paquetes
WG_MTU=1280
WG_PERSISTENT_KEEPALIVE=15
WG_DEFAULT_DNS=1.1.1.1, 8.8.8.8
WG_SUBNET=10.8.0

# Sistema
TZ=Europe/Madrid
COMPOSE_PROJECT_NAME=vpn
BACKUP_RETENTION_DAYS=30
WATCHTOWER_SCHEDULE=0 0 4 * * *
WG_MEMORY_LIMIT=512M
WG_CPU_LIMIT=1.0
